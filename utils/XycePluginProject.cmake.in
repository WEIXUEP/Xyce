cmake_minimum_required(VERSION 3.13)
project(xyce_plugin)

set(CMAKE_CXX_STANDARD 11)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

# Determine library name.
if(DEFINED PLUGIN_NAME)
  set(library_name "${PLUGIN_NAME}")
else()
  set(library_name "xyceplugin")
endif()

# Glob for source files to compile.
file(GLOB src_files CONFIGURE_DEPENDS "${CMAKE_SOURCE_DIR}/*.C")

# Reuse the Xyce installation package instead of guessing library names/paths.
find_package(Xyce CONFIG REQUIRED
  PATHS "${XYCE_INSTALL}/lib/cmake/Xyce"
  NO_DEFAULT_PATH)

# Use any compile flags that were set when building Xyce.
set(CMAKE_CXX_FLAGS "@CMAKE_CXX_FLAGS@")

# Build shared library.
add_compile_options("$<IF:$<CXX_COMPILER_ID:IntelLLVM>,-fp-model=precise,>")
add_library("${library_name}" SHARED ${src_files})
set_target_properties("${library_name}" PROPERTIES PREFIX "")
target_include_directories("${library_name}" PRIVATE
  ${CMAKE_CURRENT_SOURCE_DIR})
target_link_libraries("${library_name}" PRIVATE Xyce::XyceLib)
